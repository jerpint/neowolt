# Required — Claude Code OAuth token (from your Claude Code auth)
CLAUDE_CODE_OAUTH_TOKEN=

# Optional — Spotify integration (for music curation in digests)
SPOTIFY_ID=
SPOTIFY_SECRET=
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_USER=

# Optional — Timezone for cron scheduling
WOLT_TIMEZONE=America/New_York

# Optional — OpenRouter for digest article summarization
OPENROUTER_API_KEY=

# Optional — Model for digest generation (default: claude-haiku-4-5-20251001)
DIGEST_MODEL=
